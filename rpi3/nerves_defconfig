# ---- Custom: Bluetooth via BlueZ + D-Bus --------------------------------
# D-Bus system bus (required by bluetoothd) and the BlueZ stack/daemon.
# BLUEZ5_UTILS builds bluetoothd with the GATT client/server support we need
# built in — no separate "gatt plugin" symbol is required.
BR2_PACKAGE_DBUS=y
BR2_PACKAGE_BLUEZ5_UTILS=y
# Optional, recommended for on-device debugging (bluetoothctl). Confirm the
# exact sub-option spelling against this buildroot's
# package/bluez5_utils/Config.in before relying on it:
#   BR2_PACKAGE_BLUEZ5_UTILS_CLIENT=y   # bluetoothctl (selects readline)
# If you need newer org.bluez interfaces (e.g. AdvertisementMonitor), also:
#   BR2_PACKAGE_BLUEZ5_UTILS_EXPERIMENTAL=y   # and start bluetoothd --experimental
#
# Controller firmware: provided via the rootfs overlay at
# rootfs_overlay/lib/firmware/brcm/*.hcd (synced from ../shared/firmware by
# `make sync`; see shared/firmware/README.md). The stock image ships only
# WiFi brcmfmac blobs and BlueZ carries no controller firmware, so the kernel
# btbcm driver needs these. We ship the whole Pi BT set; btbcm loads the one
# matching the detected chip (rpi3 boards: BCM43430A1 for 3B/CM3, BCM4345C0
# for 3B+/3A+, BCM43430B0 for Zero 2 W). Covered by the checksum via the
# package_files() "rootfs_overlay" entry.
